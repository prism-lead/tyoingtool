    padding: 13px 32px !important;
    font-family: Inter, sans-serif !important;
    font-size: 14px !important; font-weight: 700 !important;
    letter-spacing: .06em !important; text-transform: uppercase !important;
    cursor: pointer !important;
    box-shadow: 0 4px 16px rgba(25,25,112,.28) !important;
    transition: background .2s, transform .2s !important;
    display: none !important;
}
.sc-continue-ready .nextPage { display: inline-block !important; }
</style>

<script>
(function ($) {
    'use strict';

    var TOTAL_STEPS = 6;
    var stepsRevealed = 0;
    var done = { QS1:false, QZIP:false, QAGE:false, QGENDER:false, QVOTE24:false, PARTY:false };

    function revealCard (id) {
        var $c = $('#' + id);
        if ($c.is(':visible')) return;
        stepsRevealed++;
        $c.show();
        updateProgress();
        $('html,body').animate({ scrollTop: $c.offset().top - 80 }, 460, 'swing');
    }

    function updateProgress () {
        var pct = Math.round(stepsRevealed / TOTAL_STEPS * 100);
        $('#sc-progress-fill').css('width', pct + '%');
        $('#sc-progress-label').text(stepsRevealed + ' of ' + TOTAL_STEPS + ' Questions');
    }

    function allDone () {
        return done.QS1 && done.QZIP && done.QAGE && done.QGENDER && done.QVOTE24 && done.PARTY;
    }

    function checkContinue () {
        if (allDone()) {
            $('body').addClass('sc-continue-ready');
        }
    }

    function makeBallotBars (wrapperId) {
        var $wrap  = $(wrapperId + ' .ballot-edge-bars').empty();
        var nRows  = $(wrapperId + ' .ballot-row').length;
        for (var i = 0; i < nRows + 2; i++) {
            $wrap.append(
                $('<div class="ballot-edge-bar">').css('width', (Math.random() * 8 + 4) + 'px')
            );
        }
    }

    $(document).ready(function () {

        ['QS1','QZIP','QAGE','QGENDER','QVOTE24','QS5','QS5A','QS5B'].forEach(function (lbl) {
            $('#q_' + lbl).addClass('sc-native-hidden');
        });

        makeBallotBars('#ballot-gender');
        makeBallotBars('#ballot-vote24');

        $('#sc-start-btn').on('click', function () {
            $(this).prop('disabled', true).text("Let's go!");
            $('#sc-progress-wrap').slideDown(280);
            revealCard('card-qs1');
        });

        $(document).on('click', '.qs1-btn', function () {
            var val = $(this).data('val');
            $('.qs1-btn').removeClass('sc-sel');
            $(this).addClass('sc-sel');
            $('input[name="QS1"][value="' + val + '"]').prop('checked', true).trigger('change');
            done.QS1 = true;
            setTimeout(function () { revealCard('card-qzip'); }, 320);
        });

        $(document).on('input', '.zip-digit', function () {
            var $box = $(this);
            var raw  = $box.val().replace(/\D/g, '');
            $box.val(raw.slice(0, 1));
            $box.toggleClass('zip-filled', raw.length > 0);
            if (raw.length === 1) {
                var $next = $box.nextAll('.zip-digit').first();
                if ($next.length) $next.focus();
            }
            syncZip();
        });

        $(document).on('keydown', '.zip-digit', function (e) {
            if (e.key === 'Backspace' && !$(this).val())
                $(this).prevAll('.zip-digit').first().focus();
        });

        function syncZip () {
            var zip = '';
            $('.zip-digit').each(function () { zip += $(this).val(); });
            $('input[name="QZIP"], textarea[name="QZIP"]').val(zip).trigger('change');
            if (zip.length === 5 && !done.QZIP) {
                done.QZIP = true;
                setTimeout(function () { revealCard('card-qage'); }, 300);
            }
        }

        $(document).on('click', '.zip-why-trigger', function () {
            $(this).closest('.zip-why-row').find('.zip-why-body').slideToggle(220);
        });

        $(document).on('change', '#zip-pna', function () {
            if ($(this).is(':checked')) {
                $('.zip-digit').val('').removeClass('zip-filled');
                $('input[name="QZIP"], textarea[name="QZIP"]').val('PREF').trigger('change');
                if (!done.QZIP) { done.QZIP = true; setTimeout(function () { revealCard('card-qage'); }, 300); }
            } else {
                $('input[name="QZIP"], textarea[name="QZIP"]').val('').trigger('change');
                done.QZIP = false;
            }
        });
        $(document).on('focus', '.zip-digit', function () { $('#zip-pna').prop('checked', false); });

        $(document).on('input', '.age-digit', function () {
            var $box = $(this);
            var raw  = $box.val().replace(/\D/g, '');
            $box.val(raw.slice(0, 1));
            $box.toggleClass('age-filled', raw.length > 0);
            var $next = $box.nextAll('.age-digit').first();
            if (raw.length === 1 && $next.length) $next.focus();
            syncAge();
        });

        $(document).on('keydown', '.age-digit', function (e) {
            if (e.key === 'Backspace' && !$(this).val())
                $(this).prevAll('.age-digit').first().focus();
        });

        function syncAge () {
            var age = '';
            $('.age-digit').each(function () { age += $(this).val(); });
            $('input[id*="_QAGE_"], input[name="QAGE"]').val(age).trigger('change');
            if (age.length === 2 && !done.QAGE) {
                done.QAGE = true;
                setTimeout(function () { revealCard('card-qgender'); }, 300);
            }
        }

        $(document).on('change', '#age-pna', function () {
            if ($(this).is(':checked')) {
                $('.age-digit').val('').removeClass('age-filled');
                if (!done.QAGE) { done.QAGE = true; setTimeout(function () { revealCard('card-qgender'); }, 300); }
            }
        });
        $(document).on('focus', '.age-digit', function () { $('#age-pna').prop('checked', false); });

        $(document).on('click', '#ballot-gender .ballot-row', function () {
            var val = $(this).data('val');
            $('#ballot-gender .ballot-row').removeClass('sc-sel');
            $(this).addClass('sc-sel');
            $('input[name="QGENDER"][value="' + val + '"]').prop('checked', true).trigger('change');
            if (!done.QGENDER) {
                done.QGENDER = true;
                setTimeout(function () { revealCard('card-qvote24'); }, 360);
            }
        });

        $(document).on('click', '#ballot-vote24 .ballot-row', function () {
            var val = $(this).data('val');
            $('#ballot-vote24 .ballot-row').removeClass('sc-sel');
            $(this).addClass('sc-sel');
            $('input[name="QVOTE24"][value="' + val + '"]').prop('checked', true).trigger('change');
            if (!done.QVOTE24) {
                done.QVOTE24 = true;
                setTimeout(function () { revealCard('card-party'); }, 360);
            }
        });

        $(document).on('click', '.party-main-btn', function () {
            var val   = $(this).data('val');
            var label = $(this).find('span').last().text().trim();
            $('.party-main-btn').removeClass('sc-sel');
            $(this).addClass('sc-sel');
            $('input[name="QS5"][value="' + val + '"]').prop('checked', true).trigger('change');
            $('#qs5a-pipe').text(label.replace(/\/.*/, '').trim());
            $('.party-sub').slideUp(150, function () {
                if (val === '1' || val === '2') {
                    $('#party-sub-a').slideDown(280);
                } else {
                    $('#party-sub-b').slideDown(280);
                }
            });
        });

        $(document).on('click', '#party-sub-a .party-sub-btn', function () {
            $('#party-sub-a .party-sub-btn').removeClass('sc-sel');
            $(this).addClass('sc-sel');
            $('input[name="QS5A"][value="' + $(this).data('val') + '"]').prop('checked', true).trigger('change');
            done.PARTY = true; checkContinue();
        });

        $(document).on('click', '#party-sub-b .party-lean-btn', function () {
            $('#party-sub-b .party-lean-btn').removeClass('sc-sel');
            $(this).addClass('sc-sel');
            $('input[name="QS5B"][value="' + $(this).data('val') + '"]').prop('checked', true).trigger('change');
            done.PARTY = true; checkContinue();
        });

    });
}(jQuery));
</script>
]]></style>




