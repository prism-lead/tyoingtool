}
.ballot-edge-bar { height: 6px; background: #111; border-radius: 1px; }

.ballot-row {
    display: flex; align-items: center;
    padding: 7px 0; border-bottom: 1px dotted #bbb;
    cursor: pointer; position: relative;
    transition: background .12s;
    -webkit-tap-highlight-color: transparent;
}
.ballot-row:last-child { border-bottom: none; }
.ballot-row:hover { background: rgba(0,0,0,.03); }

.ballot-oval-wrap { width: 48px; flex-shrink: 0; display: flex; justify-content: center; }
.ballot-oval {
    width: 38px; height: 19px;
    border: 2.5px solid #333; border-radius: 50%;
    background: transparent;
    transition: background .15s;
}
.ballot-row.sc-sel .ballot-oval { background: #222; }
.ballot-label {
    font-size: 13.5px; color: #1a1a1a; font-weight: 600;
    letter-spacing: .02em; line-height: 1.3; padding-left: 4px; flex: 1;
}
.ballot-label .party-tag { font-size: 11px; color: #888; font-weight: 400; margin-left: 5px; }

.party-main-btns {
    display: flex; gap: 16px;
    justify-content: center; flex-wrap: wrap; margin-bottom: 6px;
}
.party-btn {
    display: flex; flex-direction: column;
    align-items: center; gap: 8px; cursor: pointer;
    padding: 14px 20px; border: 2px solid #e0e0e0;
    border-radius: 13px; min-width: 84px; background: #fff;
    transition: border-color .2s, box-shadow .2s, background .2s;
    -webkit-tap-highlight-color: transparent;
}
.party-btn:hover { border-color: #191970; box-shadow: 0 4px 14px rgba(25,25,112,.14); }
.party-btn.sc-sel { border-color: #191970; background: #f0f4ff; }
.party-btn img { width: 50px; height: 50px; object-fit: contain; }
.party-btn > span { font-size: 12px; font-weight: 700; letter-spacing: .05em; color: #555; text-transform: uppercase; text-align: center; }
.party-ind { min-width: unset !important; padding: 12px 22px !important; }

.party-sub {
    display: none; margin-top: 18px;
    padding-top: 16px; border-top: 1px solid #e8e8e8;
    animation: scReveal .3s ease forwards;
}
.party-sub .sc-q-text { font-size: 16px; margin-bottom: 14px; }

.party-sub-btns { display: flex; gap: 12px; flex-wrap: wrap; }
.party-sub-btn {
    flex: 1; min-width: 120px; padding: 12px 14px;
    border: 2px solid #ddd; border-radius: 10px;
    background: #fff; cursor: pointer;
    font-family: Inter, sans-serif; font-size: 14px; font-weight: 600;
    color: #333; text-align: center;
    transition: border-color .18s, background .18s;
    -webkit-tap-highlight-color: transparent;
}
.party-sub-btn:hover { border-color: #191970; }
.party-sub-btn.sc-sel { border-color: #191970; background: #f0f4ff; color: #191970; }

.party-lean-btns { display: flex; flex-direction: column; gap: 7px; }
.party-lean-btn {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px; border: 2px solid #ddd; border-radius: 10px;
    background: #fff; cursor: pointer;
    transition: border-color .18s, background .18s;
    -webkit-tap-highlight-color: transparent;
}
.party-lean-btn:hover { border-color: #191970; }
.party-lean-btn.sc-sel { border-color: #191970; background: #f0f4ff; }
.party-lean-btn img { width: 30px; height: 30px; object-fit: contain; flex-shrink: 0; }
.party-lean-btn > span { font-size: 14px; font-weight: 600; color: #333; font-family: Inter, sans-serif; }

#sc-footer {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    background: var(--bg1, #f0f8ff);
    border-top: 1px solid rgba(25,25,112,.10);
    padding: 9px 20px;
    text-align: center;
    font-size: 10.5px; color: #aaa; font-family: Inter, sans-serif; line-height: 1.4;
}
.nextPage, input[type="submit"].button {
    background: #191970 !important;
