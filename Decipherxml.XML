  <div id="sc-progress-wrap">
    <div id="sc-progress-track"><div id="sc-progress-fill"></div></div>
    <div id="sc-progress-label"></div>
  </div>

  <div class="sc-card sc-intro" id="card-intro">
    <div class="intro-logo-wrap">
      <img src="[rel prism-logo.svg]" alt="PRISM"
           onerror="this.style.display='none'">
    </div>
    <p class="intro-body">
      Thanks for taking part. This survey helps us understand how people
      think about health&nbsp;care and public policy today. There are no
      right or wrong answers&thinsp;&mdash;&thinsp;we&rsquo;re interested
      in&nbsp;<em>your</em>&nbsp;point of view.<br><br>Let&rsquo;s begin.
    </p>
    <button id="sc-start-btn" type="button">READY. GET. GO!</button>
  </div>

  <div class="sc-card" id="card-qs1">
    <div class="sc-q-label">1 of 6 Questions</div>
    <div class="sc-q-text">Are you registered to vote?</div>

    <div class="qs1-btn-group">

      <div class="qs1-btn qs1-yes" data-val="1" tabindex="0" role="radio" aria-label="Yes">
        <div class="qs1-shape">&#10003;</div>
        <span class="qs1-btn-label">YES</span>
      </div>

      <div class="qs1-btn qs1-no" data-val="2" tabindex="0" role="radio" aria-label="No">
        <div class="qs1-shape">&#10005;</div>
        <span class="qs1-btn-label">NO</span>
      </div>

      <div class="qs1-btn qs1-ns" data-val="99" tabindex="0" role="radio" aria-label="Not Sure">
        <div class="qs1-shape">Not Sure</div>
      </div>

    </div>
  </div>

  <div class="sc-card" id="card-qzip">
    <div class="sc-q-label">2 of 6 Questions</div>
    <div class="sc-q-text">Please enter your 5-digit Zip Code</div>
    <p style="font-size:12.5px;color:#888;margin:-12px 0 14px;font-family:Inter,sans-serif;">
      (the Zip Code of your primary residence where you are registered to vote)
    </p>

    <div class="zip-digits-row">
      <input class="zip-digit" type="tel" maxlength="1" inputmode="numeric"
             pattern="[0-9]*" autocomplete="off" aria-label="ZIP digit 1">
      <input class="zip-digit" type="tel" maxlength="1" inputmode="numeric"
             pattern="[0-9]*" autocomplete="off" aria-label="ZIP digit 2">
      <input class="zip-digit" type="tel" maxlength="1" inputmode="numeric"
             pattern="[0-9]*" autocomplete="off" aria-label="ZIP digit 3">
      <input class="zip-digit" type="tel" maxlength="1" inputmode="numeric"
             pattern="[0-9]*" autocomplete="off" aria-label="ZIP digit 4">
      <input class="zip-digit" type="tel" maxlength="1" inputmode="numeric"
             pattern="[0-9]*" autocomplete="off" aria-label="ZIP digit 5">
    </div>

    <div class="zip-why-row">
      <button class="zip-why-trigger" type="button">
        <span class="zip-why-icon">?</span>
        <span style="font-size:12px;letter-spacing:.05em;text-transform:uppercase;font-weight:600;">
          WHY DO WE ASK THIS?
        </span>
      </button>
      <div class="zip-why-body">
        Your ZIP code helps us ensure we're hearing from people across different parts
        of the country, building a representative sample.
        <strong>FUN FACT:</strong> ZIP codes tie you to your congressional district, so we can ask
        follow‑up questions about your community — they never reveal your name or exact address.
      </div>
    </div>

    <label class="sc-pna-row">
      <input class="sc-pna-chk" id="zip-pna" type="checkbox">
      <span>Prefer not to answer</span>
    </label>
  </div>

  <div class="sc-card" id="card-qage">
    <div class="sc-q-label">3 of 6 Questions</div>
    <div class="sc-q-text">What is your age?</div>
    <div class="age-instruction">Enter two digits &mdash; e.g., &ldquo;4&rdquo; then &ldquo;5&rdquo; for age 45</div>

    <div class="age-digits-row">
      <input class="age-digit" type="tel" maxlength="1" inputmode="numeric"
             pattern="[0-9]*" autocomplete="off" aria-label="Age tens digit">
      <input class="age-digit" type="tel" maxlength="1" inputmode="numeric"
             pattern="[0-9]*" autocomplete="off" aria-label="Age units digit">
    </div>

    <label class="sc-pna-row">
      <input class="sc-pna-chk" id="age-pna" type="checkbox">
      <span>Prefer not to respond</span>
    </label>
  </div>

  <div class="sc-card" id="card-qgender">
    <div class="sc-q-label">4 of 6 Questions</div>
    <div class="sc-q-text">Which of the following best describes your <strong>gender?</strong></div>

    <div class="ballot-card-inner" id="ballot-gender">
      <div class="ballot-edge-bars"></div>

      <div class="ballot-row" data-val="1">
        <div class="ballot-oval-wrap"><span class="ballot-oval"></span></div>
        <span class="ballot-label">Male</span>
      </div>
      <div class="ballot-row" data-val="2">
        <div class="ballot-oval-wrap"><span class="ballot-oval"></span></div>
        <span class="ballot-label">Female</span>
      </div>
      <div class="ballot-row" data-val="3">
        <div class="ballot-oval-wrap"><span class="ballot-oval"></span></div>
        <span class="ballot-label">Other</span>
      </div>
    </div>
  </div>

  <div class="sc-card" id="card-qvote24">
    <div class="sc-q-label">5 of 6 Questions</div>
    <div class="sc-q-text">Who did you vote for in the latest&nbsp;(2024) Presidential election?</div>

    <div class="ballot-card-inner" id="ballot-vote24">
      <div class="ballot-edge-bars"></div>

      <div class="ballot-row" data-val="1">
        <div class="ballot-oval-wrap"><span class="ballot-oval"></span></div>
        <span class="ballot-label">
          Donald J Trump <span class="party-tag">(R)</span>
        </span>
      </div>
      <div class="ballot-row" data-val="2">
        <div class="ballot-oval-wrap"><span class="ballot-oval"></span></div>
        <span class="ballot-label">
          Kamala Harris <span class="party-tag">(D)</span>
        </span>
      </div>
      <div class="ballot-row" data-val="3">
        <div class="ballot-oval-wrap"><span class="ballot-oval"></span></div>
        <span class="ballot-label">Another Candidate</span>
      </div>
      <div class="ballot-row" data-val="4">
        <div class="ballot-oval-wrap"><span class="ballot-oval"></span></div>
        <span class="ballot-label">I didn&rsquo;t have the chance to vote in this election</span>
      </div>
    </div>
  </div>

  <div class="sc-card" id="card-party">
    <div class="sc-q-label">6 of 6 Questions</div>
    <div class="sc-q-text">In politics today, do you consider yourself a&hellip;?</div>

    <div class="party-main-btns">

      <div class="party-btn party-main-btn" data-val="1"
           tabindex="0" role="radio" aria-label="Republican">
        <img src="[rel icon-gop.svg]" alt="GOP"
             onerror="this.outerHTML='<span style=font-size:30px;line-height:1>🐘</span>'">
        <span>Republican</span>
      </div>

      <div class="party-btn party-main-btn" data-val="2"
           tabindex="0" role="radio" aria-label="Democrat">
        <img src="[rel icon-dem.svg]" alt="DEM"
             onerror="this.outerHTML='<span style=font-size:30px;line-height:1>🫏</span>'">
        <span>Democrat</span>
      </div>

      <div class="party-btn party-ind party-main-btn" data-val="3"
           tabindex="0" role="radio" aria-label="Independent / Other">
        <span style="font-size:11px;font-weight:700;letter-spacing:.05em;
                     color:#555;text-transform:uppercase;text-align:center;
                     line-height:1.4;">
          Independent/<br>Other
        </span>
      </div>

    </div>

    <div class="party-sub" id="party-sub-a">
      <div class="sc-q-text">
        Would you say you are a strong or not-so-strong&nbsp;<span id="qs5a-pipe">Republican</span>?
      </div>
      <div class="party-sub-btns">
        <div class="party-sub-btn" data-val="1">Strong</div>
        <div class="party-sub-btn" data-val="2">Not&nbsp;so&nbsp;strong</div>
      </div>
    </div>

    <div class="party-sub" id="party-sub-b">
      <div class="sc-q-text">Do you lean toward the&hellip;</div>
      <div class="party-lean-btns">

        <div class="party-lean-btn" data-val="1">
          <img src="[rel icon-gop.svg]" alt="GOP"
               onerror="this.outerHTML='<span style=font-size:22px>🐘</span>'">
          <span>Republicans</span>
        </div>

        <div class="party-lean-btn" data-val="2">
          <img src="[rel icon-dem.svg]" alt="DEM"
               onerror="this.outerHTML='<span style=font-size:22px>🫏</span>'">
          <span>Democrats</span>
        </div>

        <div class="party-lean-btn" data-val="3"
             style="border-style:dashed; opacity:.85;">
          <span style="font-size:22px;line-height:1;margin-right:4px;
                       font-family:'Space Mono',monospace;font-weight:700;
                       color:#888;">NO</span>
          <span>I do not lean toward either</span>
        </div>

      </div>
    </div>

  </div>

</div>
]]></html>



<radio label="QS1" optional="1">
  <title>Are you registered to vote?</title>
  <row label="r1"  value="1">Yes</row>
  <row label="r2"  value="2">No</row>
  <row label="r99" value="99">Not Sure</row>
</radio>

<text label="QZIP" optional="1" size="5" verify="zipcode">
  <title>Please enter your 5-digit ZIP Code</title>
</text>

<number label="QAGE" optional="1" size="3" verify="range(18,89)">
  <title>What is your age?</title>
</number>

<radio label="QGENDER" optional="1">
  <title>Which of the following best describes your gender?</title>
  <row label="r1" value="1">Male</row>
  <row label="r2" value="2">Female</row>
  <row label="r3" value="3">Other</row>
  <row label="r99" cond="0" value="99">Prefer not to answer</row>
</radio>

<radio label="QVOTE24" optional="1">
  <title>Who did you vote for in the latest (2024) Presidential election?</title>
  <row label="r1" value="1">Donald Trump (R)</row>
  <row label="r2" value="2">Kamala Harris (D)</row>
  <row label="r3" value="3">Someone else</row>
  <row label="r4" value="4">I did not have the chance to vote</row>
</radio>

<radio label="QS5" optional="1">
  <title>In politics today, do you consider yourself a…?</title>
  <row label="r1">Republican</row>
  <row label="r2">Democrat</row>
  <row label="r3">Independent</row>
  <row label="r4">Other</row>
</radio>

<radio label="QS5A" optional="1" cond="QS5.r1 or QS5.r2">
  <title>Would you say you are a strong or not-so strong [pipe: QS5]?</title>
  <row label="r1">Strong</row>
  <row label="r2">Not so strong</row>
</radio>

<radio label="QS5B" optional="1" cond="QS5.r3 or QS5.r4">
  <title>Do you lean towards the Republican or Democratic Party?</title>
  <row label="r1">Lean Republican</row>
  <row label="r2">Lean Democrat</row>
  <row label="r3">Neither Party</row>
</radio>


<suspend/>



<exec cond="QS1.r2 or QS1.r99">
vscreenout.val = str('QS1')
setMarker('Screened-QS1')
</exec>
<term label="Term_QS1" cond="QS1.r2 or QS1.r99">QS1 termination</term>




<exec cond="QVOTE24.r4">
vscreenout.val = str('QVOTE24')
setMarker('Screened-QVOTE24')
</exec>
<term label="Term_VOTE24" cond="QVOTE24.r4">Did not vote</term>

<exec cond="QVOTE24.r3 and QS5B.r3">
vscreenout.val = str('QS5')
setMarker('Screened-QS5')
</exec>
<term label="Term_PARTYID" cond="QVOTE24.r3 and QS5B.r3">
  Voted for someone else and is Independent
</term>

</survey>

